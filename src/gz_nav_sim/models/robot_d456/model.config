<?xml version="1.0"?>
<model>
  <name>robot_d456</name>
  <version>1.0</version>
  <sdf version="1.6">robot.sdf</sdf>
  <description>
    Diff-drive robot with Realsense D456 depth+RGB camera mounted at 0.8m height.
    Used for "depth" preset (D456 native depth → nvblox 직접) 및
    DA3/VGGT 비교 환경 (RGB 입력은 동일, 카메라 위치만 다름).
  </description>
</model>
