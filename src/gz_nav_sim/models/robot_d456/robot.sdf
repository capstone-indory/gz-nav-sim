<?xml version="1.0" ?>
<sdf version="1.6">

  <!-- D456 변형 — robot.sdf 와 거의 동일하지만 카메라가 depth(=Realsense D456) 타입,
       높이 0.8m, FOV 87°(1.518rad).  Topic은 depth만 별도 namespace(/d456)로 분리해
       DA3/VGGT가 publish하는 /camera/depth/* 와 충돌 안 나게 함.
         /camera/image_raw, /camera/camera_info  ← DA3/VGGT 입력 (변경 X)
         /d456/depth/image_raw, /d456/depth/camera_info, /d456/depth/points  ← 직접 depth 사용 -->
  <model name="robot_d456">

    <!-- 본체 -->
    <link name="base_link">
      <inertial>
        <mass>8.0</mass>
        <inertia>
          <ixx>0.2</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.2</iyy><iyz>0</iyz><izz>0.3</izz>
        </inertia>
      </inertial>

      <collision name="col">
        <geometry>
          <cylinder>
            <radius>0.18</radius>
            <length>0.12</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="vis">
        <geometry>
          <cylinder>
            <radius>0.18</radius>
            <length>0.12</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.5 0.8 1</ambient>
          <diffuse>0.2 0.5 0.8 1</diffuse>
        </material>
      </visual>

      <!-- D456 카메라 마운트 visual (0~0.8m 사이 막대) -->
      <visual name="cam_mast">
        <pose>0.16 0 0.4 0 0 0</pose>
        <geometry>
          <box>
            <size>0.04 0.04 0.7</size>
          </box>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>

      <!-- 2D LiDAR — SLAMTEC RPLIDAR C1 spec (robot.sdf와 동일) -->
      <sensor name="lidar" type="ray">
        <pose>0 0 0.1 0 0 0</pose>
        <update_rate>10</update_rate>
        <always_on>true</always_on>
        <visualize>false</visualize>
        <ray>
          <scan>
            <horizontal>
              <samples>500</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.05</min>
            <max>12.0</max>
            <resolution>0.015</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.03</stddev>
          </noise>
        </ray>
        <plugin name="lidar_ros" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <namespace>/</namespace>
            <remapping>~/out:=scan</remapping>
          </ros>
          <output_type>sensor_msgs/LaserScan</output_type>
          <frame_name>base_link</frame_name>
        </plugin>
      </sensor>

      <!-- Realsense D456 (depth + RGB)
           - 위치: 0.16 forward, z=0.80 (마스트 끝)
           - HFOV 87° = 1.518 rad (D456 spec)
           - depth range 0.3~20m (D456 ideal)
           - 색상은 /camera/image_raw (DA3/VGGT 입력), depth는 /d456/depth/* 로 분리.
           -->
      <sensor name="d456_camera" type="depth">
        <pose>0.16 0 0.80 0 0 0</pose>
        <update_rate>15</update_rate>
        <always_on>true</always_on>
        <visualize>false</visualize>
        <camera>
          <horizontal_fov>1.518</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.3</near>
            <far>20.0</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.005</stddev>
          </noise>
        </camera>
        <plugin name="d456_ros" filename="libgazebo_ros_camera.so">
          <ros>
            <namespace>/</namespace>
            <!-- depth 출력만 /d456/depth/* 로 remap. RGB는 /camera/* 그대로 -->
            <remapping>camera/depth/image_raw:=d456/depth/image_raw</remapping>
            <remapping>camera/depth/camera_info:=d456/depth/camera_info</remapping>
            <remapping>camera/depth/points:=d456/depth/points</remapping>
          </ros>
          <camera_name>camera</camera_name>
          <frame_name>camera_optical_frame</frame_name>
          <min_depth>0.3</min_depth>
          <max_depth>20.0</max_depth>
        </plugin>
      </sensor>
    </link>

    <!-- 왼쪽 바퀴 -->
    <link name="left_wheel">
      <pose>0 0.19 -0.04 -1.5708 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.001</iyy><iyz>0</iyz><izz>0.001</izz>
        </inertia>
      </inertial>
      <collision name="col">
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>0.8</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="vis">
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <!-- 오른쪽 바퀴 -->
    <link name="right_wheel">
      <pose>0 -0.19 -0.04 -1.5708 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.001</iyy><iyz>0</iyz><izz>0.001</izz>
        </inertia>
      </inertial>
      <collision name="col">
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>0.8</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="vis">
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <!-- 앞 보조 캐스터 -->
    <link name="front_caster">
      <pose>0.16 0 -0.08 -1.5708 0 0</pose>
      <inertial>
        <mass>0.10</mass>
        <inertia>
          <ixx>0.0001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.0001</iyy><iyz>0</iyz><izz>0.0001</izz>
        </inertia>
      </inertial>
      <collision name="col">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.1</mu>
              <mu2>0.1</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="wheel_vis">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.18 0.18 0.20 1</ambient>
          <diffuse>0.18 0.18 0.20 1</diffuse>
          <specular>0.4 0.4 0.4 1</specular>
        </material>
      </visual>
    </link>

    <joint name="front_caster_joint" type="fixed">
      <parent>base_link</parent>
      <child>front_caster</child>
    </joint>

    <!-- 뒤 보조 캐스터 -->
    <link name="rear_caster">
      <pose>-0.16 0 -0.08 -1.5708 0 0</pose>
      <inertial>
        <mass>0.10</mass>
        <inertia>
          <ixx>0.0001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.0001</iyy><iyz>0</iyz><izz>0.0001</izz>
        </inertia>
      </inertial>
      <collision name="col">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.1</mu>
              <mu2>0.1</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="wheel_vis">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.18 0.18 0.20 1</ambient>
          <diffuse>0.18 0.18 0.20 1</diffuse>
          <specular>0.4 0.4 0.4 1</specular>
        </material>
      </visual>
    </link>

    <joint name="rear_caster_joint" type="fixed">
      <parent>base_link</parent>
      <child>rear_caster</child>
    </joint>

    <!-- Diff Drive -->
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
      </ros>

      <update_rate>50</update_rate>

      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <wheel_separation>0.38</wheel_separation>
      <wheel_diameter>0.16</wheel_diameter>

      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>5.0</max_wheel_acceleration>

      <command_topic>cmd_vel</command_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>

      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>

    <plugin name="joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
        <namespace>/</namespace>
        <remapping>~/out:=joint_states</remapping>
      </ros>
      <update_rate>30</update_rate>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
  </model>
</sdf>
